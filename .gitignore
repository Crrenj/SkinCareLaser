/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sauvegardes locales (paused Supabase project)
/bd1
/bd2

# Assets réels du seed (203 MB d'images + PDFs)
# Utilisés par scripts/seed-import.cjs en local — non versionnés
/contenu_bd

# Per-user Claude Code settings (le projet-level settings.json reste versionné)
.claude/settings.local.json

# Données de prix (générées par scripts/prices-export.cjs, ne pas versionner)
/data/prices.csv
