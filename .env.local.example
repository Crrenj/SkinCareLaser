# Supabase — projet à copier depuis https://app.supabase.com/project/_/settings/api
# Public (utilisable côté client) :
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret (server-only, bypasse RLS — ne JAMAIS exposer côté client) :
# `SUPABASE_SERVICE_ROLE_KEY` est le nom canonique. `SUPABASE_SERVICE_KEY`
# est accepté en alias par src/lib/supabaseAdmin.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — double opt-in newsletter (optionnel)
# Sans ces variables, la newsletter fonctionne sans confirmation email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=FARMAU <noreply@farmau.do>

# Sentry — monitoring d'erreurs (optionnel, G-4a)
# Sans ces variables le SDK est dormant (aucun réseau, aucune erreur).
# Créer un projet sur sentry.io puis coller le DSN (le même pour les deux) :
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
