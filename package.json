{
  "name": "skincarelaser",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "playwright test",
    "test:smoke": "playwright test golden-path --project=chromium --workers=1 --reporter=line",
    "test:auth": "playwright test admin-auth account-auth --project=chromium --workers=1 --reporter=line",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest",
    "test:unit:watch": "vitest watch",
