    "parse-pdfs": "node scripts/parse-pdfs.cjs",
    "validate-catalog": "node scripts/validate-catalog.cjs",
    "prices:export": "node scripts/prices-export.cjs",
    "prices:import": "node scripts/prices-import.cjs",
    "prices:default": "node scripts/prices-set-default.cjs",
    "seed-import": "node scripts/seed-import.cjs",
    "seed:example-content": "node scripts/seed-example-content.cjs",
    "create-admin": "node scripts/create-admin-user.js",
    "favicons:build": "node scripts/build-favicons.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@sentry/nextjs": "^10.60.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "dotenv": "^17.4.2",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-intl": "^4.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.5.0",
    "resend": "^6.14.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "glob": "^13.0.6",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --no-warn-ignored"
  }
